# ── Pegasus Design Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.

ENVIRONMENT=development

# ── Database ───────────────────────────────────────────────────────────
# For Docker Compose, keep as-is. For production, set to your Postgres URL.
DB_PASSWORD=pegasus_dev
DATABASE_URL=postgresql+asyncpg://pegasus:pegasus_dev@localhost:5432/pegasus_design

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ───────────────────────────────────────────────────────────────
# REQUIRED — Change in production. Used for JWT signing.
JWT_SECRET=change_this_in_production

# ── OpenAI (AI recommendation engine) ─────────────────────────────────
# Optional — leave blank to disable AI features.
OPENAI_API_KEY=

# ── InlineIQ Integration ───────────────────────────────────────────────
# Optional — leave blank if not using InlineIQ labor sync.
INLINEIQ_API_URL=
INLINEIQ_API_KEY=

# ── Frontend — Next.js public variables ───────────────────────────────
# For local Docker: /api/v1 (Next.js proxy rewrites to backend)
# For Vercel prod:  https://your-backend-url.com/api/v1
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=/ws

# ── Backend hostname for Next.js rewrites ─────────────────────────────
# Docker Compose: http://backend:8000
# Local dev outside Docker: http://localhost:8000
BACKEND_URL=http://localhost:8000
